{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ADB Wireless Debug",
  "version": "0.1.0",
  "identifier": "com.devart.adb-wireless",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "ADB Wireless Debug",
        "width": 700,
        "height": 600,
        "minWidth": 480,
        "minHeight": 400,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
